---
const year = new Date().getFullYear()
---
<!DOCTYPE html>
<html lang="sv">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>ELS Catalyst AB</title>
  <meta name="description" content="ELS Catalyst AB - kontakta oss for mer information." />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
      background: #f9f9f9;
      color: #1a1a1a;
      min-height: 100vh;
      display: flex;
      flex-direction: column;
    }

    main {
      flex: 1;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 2rem;
    }

    .card {
      background: #fff;
      border: 1px solid #e5e5e5;
      border-radius: 12px;
      padding: 3rem 2.5rem;
      max-width: 480px;
      width: 100%;
    }

    h1 {
      font-size: 1.75rem;
      font-weight: 700;
      letter-spacing: -0.02em;
      margin-bottom: 0.5rem;
    }

    .tagline {
      color: #666;
      font-size: 0.95rem;
      margin-bottom: 2rem;
    }

    .divider {
      border: none;
      border-top: 1px solid #e5e5e5;
      margin-bottom: 2rem;
    }

    .contact-label {
      font-size: 0.75rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: #999;
      margin-bottom: 1rem;
    }

    .contact-item {
      display: flex;
      flex-direction: column;
      gap: 0.1rem;
      margin-bottom: 0.85rem;
    }

    .contact-item span {
      font-size: 0.8rem;
      color: #999;
    }

    .contact-item a,
    .contact-item p {
      font-size: 0.95rem;
      color: #1a1a1a;
      text-decoration: none;
    }

    .contact-item a:hover {
      text-decoration: underline;
    }

    footer {
      text-align: center;
      padding: 1.5rem;
      font-size: 0.8rem;
      color: #bbb;
    }
  </style>
</head>
<body>
  <main>
    <div class="card">
      <h1>ELS Catalyst AB</h1>
      <p class="tagline">Aktiebolag registrerat i Sverige</p>
      <hr class="divider" />
      <p class="contact-label">Kontakt</p>

      <div class="contact-item">
        <span>Grundare</span>
        <p>Axel Jonemyr</p>
      </div>

      <div class="contact-item">
        <span>E-post</span>
        <a href="mailto:elscatalyst@proton.me">elscatalyst@proton.me</a>
      </div>

      <div class="contact-item">
        <span>Telefon</span>
        <a href="tel:+46722440131">072-244 01 31</a>
      </div>
    </div>
  </main>
  <footer>
    &copy; {year} ELS Catalyst AB
  </footer>
</body>
</html>

---
const year = new Date().getFullYear()
---
<!DOCTYPE html>
<html lang="sv">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>ELS Catalyst – Hemsidor, UX-design och varumärkeskänsla som konverterar</title>
  <meta name="description" content="Vi bygger professionella hemsidor med genomtänkt UX och stark varumärkeskänsla — direkt med grundaren, från brief till lansering inom 3 veckor." />

  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
  <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
  <link rel="shortcut icon" href="/favicon.ico" />
  <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />

  <meta property="og:type" content="website" />
  <meta property="og:url" content="https://elscatalyst.se/" />
  <meta property="og:title" content="ELS Catalyst – Hemsidor, UX-design och varumärkeskänsla som konverterar" />
  <meta property="og:description" content="Vi bygger professionella hemsidor med genomtänkt UX och stark varumärkeskänsla — direkt med grundaren, från brief till lansering inom 3 veckor." />
  <meta property="og:image" content="https://elscatalyst.se/og-image.jpg" />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:locale" content="sv_SE" />
  <meta property="og:site_name" content="ELS Catalyst" />

  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content="ELS Catalyst – Hemsidor, UX-design och varumärkeskänsla som konverterar" />
  <meta name="twitter:description" content="Vi bygger professionella hemsidor med genomtänkt UX och stark varumärkeskänsla — direkt med grundaren, från brief till lansering inom 3 veckor." />
  <meta name="twitter:image" content="https://elscatalyst.se/og-image.jpg" />

  <link rel="canonical" href="https://elscatalyst.se/" />
  <meta name="theme-color" content="#07090b" />

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet" />

  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg: #07090b;
      --bg-2: #0c0f13;
      --surface: #101419;
      --surface-2: #141920;
      --line: #1e242c;
      --line-bright: #2a3139;
      --text: #e9ecef;
      --text-dim: #9aa3ad;
      --muted: #646c76;
      --accent: #7cff9e;
      --accent-2: #2cd27f;
      --accent-glow: rgba(124, 255, 158, 0.18);
      --accent-dim: rgba(124, 255, 158, 0.08);
      --danger: #ff5f56;
      --warning: #ffbd2e;
      --success: #27c93f;
      --radius: 10px;
      --radius-sm: 6px;
    }

    html { scroll-behavior: smooth; background: var(--bg); }

    body {
      font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
      background: var(--bg);
      color: var(--text);
      line-height: 1.6;
      font-size: 16px;
      -webkit-font-smoothing: antialiased;
      -moz-osx-font-smoothing: grayscale;
      font-feature-settings: "cv11", "ss01";
      overflow-x: hidden;
    }

    ::selection { background: var(--accent); color: var(--bg); }

    .mono { font-family: 'JetBrains Mono', ui-monospace, monospace; }

    .wrap {
      max-width: 1200px;
      margin: 0 auto;
      padding: 0 1.75rem;
    }

    /* Grid background helpers */
    .grid-bg {
      background-image:
        linear-gradient(to right, rgba(255,255,255,0.025) 1px, transparent 1px),
        linear-gradient(to bottom, rgba(255,255,255,0.025) 1px, transparent 1px);
      background-size: 48px 48px;
    }

    .dot-bg {
      background-image: radial-gradient(rgba(255,255,255,0.06) 1px, transparent 1px);
      background-size: 22px 22px;
    }

    /* Kicker/label */
    .kicker {
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.72rem;
      font-weight: 500;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      color: var(--accent);
      display: inline-flex;
      align-items: center;
      gap: 0.6rem;
    }

    .kicker::before {
      content: '';
      width: 8px;
      height: 8px;
      border: 1.5px solid var(--accent);
      border-radius: 2px;
      transform: rotate(45deg);
      display: inline-block;
    }

    /* HEADER */
    header {
      position: sticky;
      top: 0;
      z-index: 100;
      background: rgba(7, 9, 11, 0.78);
      backdrop-filter: blur(16px) saturate(140%);
      -webkit-backdrop-filter: blur(16px) saturate(140%);
      border-bottom: 1px solid var(--line);
    }

    .header-inner {
      display: flex;
      align-items: center;
      justify-content: space-between;
      height: 64px;
    }

    .logo {
      display: flex;
      align-items: center;
      gap: 0.65rem;
      text-decoration: none;
      color: var(--text);
    }

    .logo-mark {
      width: 28px;
      height: 28px;
      background: var(--accent);
      border-radius: 6px;
      display: flex;
      align-items: center;
      justify-content: center;
      color: var(--bg);
      font-weight: 800;
      font-size: 0.82rem;
      letter-spacing: -0.02em;
      position: relative;
      box-shadow: 0 0 28px var(--accent-glow);
    }

    .logo-mark::after {
      content: '';
      position: absolute;
      inset: -1px;
      border-radius: 7px;
      background: linear-gradient(135deg, rgba(255,255,255,0.3), transparent 50%);
      pointer-events: none;
    }

    .logo-text {
      font-weight: 600;
      font-size: 0.95rem;
      letter-spacing: -0.01em;
      color: var(--text);
    }

    nav {
      display: flex;
      align-items: center;
      gap: 2rem;
    }

    .nav-link {
      color: var(--text-dim);
      text-decoration: none;
      font-size: 0.875rem;
      font-weight: 500;
      transition: color 0.2s;
      position: relative;
    }

    .nav-link:hover { color: var(--text); }

    .btn-nav {
      background: var(--surface);
      color: var(--text) !important;
      padding: 0.55rem 1rem 0.55rem 0.85rem;
      border-radius: 100px;
      font-weight: 500;
      font-size: 0.875rem;
      text-decoration: none;
      border: 1px solid var(--line-bright);
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      transition: border-color 0.2s, background 0.2s;
    }

    .btn-nav .status-dot {
      width: 7px;
      height: 7px;
      background: var(--accent);
      border-radius: 50%;
      box-shadow: 0 0 8px var(--accent);
      animation: blink 2s infinite ease-in-out;
    }

    @keyframes blink {
      0%, 100% { opacity: 1; }
      50% { opacity: 0.35; }
    }

    .btn-nav:hover { border-color: var(--accent); background: var(--surface-2); }

    /* HERO */
    .hero {
      position: relative;
      padding: 7rem 0 5rem;
      overflow: hidden;
      border-bottom: 1px solid var(--line);
    }

    .hero::before {
      content: '';
      position: absolute;
      inset: 0;
      background-image:
        linear-gradient(to right, rgba(255,255,255,0.03) 1px, transparent 1px),
        linear-gradient(to bottom, rgba(255,255,255,0.03) 1px, transparent 1px);
      background-size: 56px 56px;
      mask-image: radial-gradient(ellipse 80% 60% at 50% 30%, #000 20%, transparent 90%);
      -webkit-mask-image: radial-gradient(ellipse 80% 60% at 50% 30%, #000 20%, transparent 90%);
      pointer-events: none;
    }

    .hero::after {
      content: '';
      position: absolute;
      top: -20%;
      left: 50%;
      transform: translateX(-50%);
      width: 900px;
      height: 900px;
      background: radial-gradient(circle, var(--accent-glow) 0%, transparent 60%);
      pointer-events: none;
      opacity: 0.7;
    }

    .hero-inner {
      position: relative;
      z-index: 1;
      text-align: center;
    }

    .hero-badge {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      background: var(--surface);
      border: 1px solid var(--line-bright);
      border-radius: 100px;
      padding: 0.35rem 0.85rem 0.35rem 0.45rem;
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.72rem;
      font-weight: 500;
      color: var(--text-dim);
      letter-spacing: 0.04em;
      margin-bottom: 2rem;
    }

    .hero-badge-pill {
      background: var(--accent);
      color: var(--bg);
      padding: 0.15rem 0.5rem;
      border-radius: 100px;
      font-weight: 600;
      font-size: 0.68rem;
      letter-spacing: 0.05em;
    }

    .hero h1 {
      font-size: clamp(2.4rem, 6vw, 4.75rem);
      font-weight: 700;
      letter-spacing: -0.035em;
      line-height: 1.02;
      color: var(--text);
      max-width: 16ch;
      margin: 0 auto 1.5rem;
    }

    .hero h1 .accent-text {
      background: linear-gradient(120deg, var(--accent) 0%, #a8ffc2 50%, var(--accent) 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
      position: relative;
    }

    .hero-sub {
      font-size: 1.1rem;
      color: var(--text-dim);
      max-width: 56ch;
      margin: 0 auto 2.5rem;
      line-height: 1.6;
    }

    .hero-ctas {
      display: inline-flex;
      gap: 0.75rem;
      flex-wrap: wrap;
      justify-content: center;
    }

    .btn-primary {
      display: inline-flex;
      align-items: center;
      gap: 0.6rem;
      background: var(--accent);
      color: var(--bg);
      padding: 0.85rem 1.4rem;
      border-radius: var(--radius);
      font-weight: 600;
      font-size: 0.95rem;
      text-decoration: none;
      transition: transform 0.2s, box-shadow 0.2s;
      box-shadow: 0 0 0 1px var(--accent), 0 8px 32px rgba(124, 255, 158, 0.22);
      border: none;
      cursor: pointer;
      letter-spacing: -0.005em;
    }

    .btn-primary svg { transition: transform 0.25s; }
    .btn-primary:hover { transform: translateY(-1px); box-shadow: 0 0 0 1px var(--accent), 0 12px 40px rgba(124, 255, 158, 0.32); }
    .btn-primary:hover svg { transform: translateX(3px); }

    .btn-secondary {
      display: inline-flex;
      align-items: center;
      gap: 0.55rem;
      background: var(--surface);
      color: var(--text);
      padding: 0.85rem 1.4rem;
      border-radius: var(--radius);
      font-weight: 500;
      font-size: 0.95rem;
      text-decoration: none;
      border: 1px solid var(--line-bright);
      transition: border-color 0.2s, background 0.2s;
    }

    .btn-secondary:hover { border-color: var(--accent); background: var(--surface-2); }

    /* Hero stats */
    .hero-stats {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1px;
      margin: 5rem auto 0;
      max-width: 820px;
      background: var(--line);
      border: 1px solid var(--line);
      border-radius: var(--radius);
      overflow: hidden;
    }

    .stat {
      background: var(--bg-2);
      padding: 1.75rem 1rem;
      text-align: center;
    }

    .stat-num {
      font-size: 1.75rem;
      font-weight: 700;
      color: var(--text);
      letter-spacing: -0.025em;
      line-height: 1;
      font-variant-numeric: tabular-nums;
    }

    .stat-num.accent { color: var(--accent); }

    .stat-label {
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.7rem;
      color: var(--text-dim);
      margin-top: 0.6rem;
      letter-spacing: 0.04em;
      text-transform: uppercase;
    }

    /* SECTIONS */
    section.block {
      padding: 6.5rem 0;
      position: relative;
    }

    .section-head {
      max-width: 720px;
      margin-bottom: 3.5rem;
    }

    .section-head.center {
      margin-left: auto;
      margin-right: auto;
      text-align: center;
    }

    .section-title {
      font-size: clamp(1.9rem, 3.5vw, 2.75rem);
      font-weight: 700;
      letter-spacing: -0.03em;
      line-height: 1.1;
      color: var(--text);
      margin-top: 0.9rem;
      margin-bottom: 1rem;
    }

    .section-desc {
      font-size: 1.05rem;
      color: var(--text-dim);
      line-height: 1.65;
      max-width: 60ch;
    }

    .section-head.center .section-desc { margin-left: auto; margin-right: auto; }

    /* SERVICES */
    #tjanster { background: var(--bg); position: relative; }

    #tjanster::before {
      content: '';
      position: absolute;
      inset: 0;
      background-image: radial-gradient(rgba(124, 255, 158, 0.04) 1px, transparent 1px);
      background-size: 24px 24px;
      mask-image: radial-gradient(ellipse 70% 50% at 50% 50%, #000 30%, transparent 80%);
      -webkit-mask-image: radial-gradient(ellipse 70% 50% at 50% 50%, #000 30%, transparent 80%);
      pointer-events: none;
    }

    #tjanster .wrap { position: relative; z-index: 1; }

    .services-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1.25rem;
    }

    .service-card {
      background: var(--surface);
      border: 1px solid var(--line);
      border-radius: var(--radius);
      padding: 1.75rem;
      transition: border-color 0.25s, transform 0.25s, box-shadow 0.25s;
      position: relative;
      overflow: hidden;
      display: flex;
      flex-direction: column;
    }

    .service-card::before {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      height: 1px;
      background: linear-gradient(90deg, transparent, var(--accent), transparent);
      opacity: 0;
      transition: opacity 0.3s;
    }

    .service-card:hover {
      border-color: var(--line-bright);
      transform: translateY(-2px);
      box-shadow: 0 16px 48px -20px rgba(0,0,0,0.6), 0 0 0 1px var(--line-bright);
    }

    .service-card:hover::before { opacity: 1; }

    .service-head {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 1.25rem;
    }

    .service-icon {
      width: 40px;
      height: 40px;
      background: var(--surface-2);
      border: 1px solid var(--line-bright);
      border-radius: 8px;
      display: flex;
      align-items: center;
      justify-content: center;
      color: var(--accent);
    }

    .service-tag {
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.68rem;
      color: var(--text-dim);
      letter-spacing: 0.05em;
      padding: 0.25rem 0.55rem;
      background: var(--bg-2);
      border: 1px solid var(--line);
      border-radius: 100px;
    }

    .service-card h3 {
      font-size: 1.3rem;
      font-weight: 600;
      letter-spacing: -0.02em;
      margin-bottom: 0.6rem;
      color: var(--text);
    }

    .service-card > p {
      font-size: 0.925rem;
      color: var(--text-dim);
      line-height: 1.6;
      margin-bottom: 1.5rem;
    }

    .service-list {
      list-style: none;
      display: flex;
      flex-direction: column;
      gap: 0.55rem;
      margin-top: auto;
      padding-top: 1.25rem;
      border-top: 1px solid var(--line);
    }

    .service-list li {
      font-size: 0.875rem;
      color: var(--text-dim);
      display: flex;
      align-items: center;
      gap: 0.65rem;
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.8rem;
    }

    .service-list li svg {
      color: var(--accent);
      flex-shrink: 0;
    }

    /* USPs */
    #varfor {
      background: var(--bg-2);
      border-top: 1px solid var(--line);
      border-bottom: 1px solid var(--line);
    }

    .usps-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 1.25rem;
    }

    .usp {
      background: var(--surface);
      border: 1px solid var(--line);
      border-radius: var(--radius);
      padding: 1.5rem;
      transition: border-color 0.2s, background 0.2s;
    }

    .usp:hover { border-color: var(--line-bright); background: var(--surface-2); }

    .usp-top {
      display: flex;
      align-items: center;
      gap: 0.6rem;
      margin-bottom: 1rem;
    }

    .usp-num {
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.7rem;
      font-weight: 500;
      color: var(--accent);
      letter-spacing: 0.05em;
    }

    .usp-icon {
      width: 18px;
      height: 18px;
      color: var(--accent);
    }

    .usp h4 {
      font-size: 1.05rem;
      font-weight: 600;
      letter-spacing: -0.015em;
      margin-bottom: 0.4rem;
      color: var(--text);
    }

    .usp p {
      font-size: 0.875rem;
      color: var(--text-dim);
      line-height: 1.55;
    }

    /* CASES */
    #case { background: var(--bg); position: relative; }

    .cases-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1.25rem;
    }

    .case-card {
      background: var(--surface);
      border: 1px solid var(--line);
      border-radius: var(--radius);
      padding: 1.5rem;
      transition: border-color 0.25s, transform 0.25s;
      display: flex;
      flex-direction: column;
      text-decoration: none;
      color: inherit;
    }

    .case-card:hover { border-color: var(--line-bright); transform: translateY(-2px); }
    .case-card:hover .browser-screenshot { opacity: 0.92; }
    .case-card:hover .case-arrow { transform: translate(2px, -2px); color: var(--accent); }

    .browser-mockup {
      border-radius: var(--radius-sm);
      overflow: hidden;
      border: 1px solid var(--line);
      margin-bottom: 1.25rem;
      background: var(--bg-2);
    }

    .browser-bar {
      background: var(--surface-2);
      padding: 0.5rem 0.7rem;
      display: flex;
      align-items: center;
      gap: 0.55rem;
      border-bottom: 1px solid var(--line);
    }

    .browser-dots {
      display: flex;
      gap: 0.3rem;
    }

    .browser-dot {
      width: 8px;
      height: 8px;
      border-radius: 50%;
    }

    .browser-dot:nth-child(1) { background: var(--danger); }
    .browser-dot:nth-child(2) { background: var(--warning); }
    .browser-dot:nth-child(3) { background: var(--success); }

    .browser-url {
      flex: 1;
      background: var(--bg);
      border: 1px solid var(--line);
      border-radius: 4px;
      padding: 0.2rem 0.55rem;
      font-size: 0.7rem;
      color: var(--text-dim);
      font-family: 'JetBrains Mono', monospace;
    }

    .browser-screenshot {
      width: 100%;
      height: 180px;
      object-fit: cover;
      object-position: top;
      display: block;
      transition: opacity 0.35s;
    }

    .case-title-row {
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      gap: 1rem;
      margin-bottom: 0.5rem;
    }

    .case-card h3 {
      font-size: 1.15rem;
      font-weight: 600;
      color: var(--text);
      letter-spacing: -0.02em;
    }

    .case-arrow {
      color: var(--text-dim);
      flex-shrink: 0;
      transition: transform 0.25s, color 0.25s;
    }

    .case-tag {
      display: inline-block;
      background: var(--accent-dim);
      color: var(--accent);
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.68rem;
      font-weight: 500;
      letter-spacing: 0.04em;
      padding: 0.25rem 0.55rem;
      border-radius: 4px;
      margin-bottom: 1rem;
      border: 1px solid var(--accent-dim);
    }

    .case-card > p {
      font-size: 0.9rem;
      color: var(--text-dim);
      line-height: 1.6;
      margin-bottom: 1.25rem;
    }

    .case-results {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1rem;
      margin-top: auto;
      padding-top: 1rem;
      border-top: 1px solid var(--line);
    }

    .case-result-num {
      font-size: 1.25rem;
      font-weight: 700;
      color: var(--accent);
      letter-spacing: -0.02em;
      line-height: 1.1;
      font-variant-numeric: tabular-nums;
    }

    .case-result-label {
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.68rem;
      color: var(--text-dim);
      margin-top: 0.3rem;
      letter-spacing: 0.03em;
    }

    /* CONTACT */
    #kontakt {
      background: var(--bg-2);
      border-top: 1px solid var(--line);
      position: relative;
    }

    .contact-wrap {
      display: grid;
      grid-template-columns: 1fr 1.15fr;
      gap: 3.5rem;
      margin-top: 3rem;
      align-items: start;
    }

    .contact-info {
      display: flex;
      flex-direction: column;
      gap: 1rem;
    }

    .contact-item {
      background: var(--surface);
      border: 1px solid var(--line);
      border-radius: var(--radius);
      padding: 1.1rem 1.25rem;
      display: flex;
      align-items: center;
      gap: 1rem;
      transition: border-color 0.2s;
    }

    .contact-item:hover { border-color: var(--line-bright); }

    .contact-item-icon {
      width: 38px;
      height: 38px;
      background: var(--surface-2);
      border: 1px solid var(--line-bright);
      border-radius: 8px;
      display: flex;
      align-items: center;
      justify-content: center;
      color: var(--accent);
      flex-shrink: 0;
    }

    .contact-item-label {
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.68rem;
      color: var(--text-dim);
      letter-spacing: 0.05em;
      text-transform: uppercase;
      margin-bottom: 0.15rem;
    }

    .contact-item-value {
      font-size: 0.95rem;
      font-weight: 500;
      color: var(--text);
    }

    .contact-item-value a {
      color: var(--text);
      text-decoration: none;
      transition: color 0.2s;
    }

    .contact-item-value a:hover { color: var(--accent); }

    .contact-form {
      background: var(--surface);
      border: 1px solid var(--line);
      border-radius: var(--radius);
      padding: 2rem;
      position: relative;
    }

    .contact-form-head {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 1.5rem;
      padding-bottom: 1.25rem;
      border-bottom: 1px solid var(--line);
    }

    .contact-form h3 {
      font-size: 1.1rem;
      font-weight: 600;
      letter-spacing: -0.015em;
      color: var(--text);
    }

    .contact-form-meta {
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.7rem;
      color: var(--text-dim);
      display: inline-flex;
      align-items: center;
      gap: 0.35rem;
    }

    .contact-form-meta::before {
      content: '';
      width: 6px;
      height: 6px;
      background: var(--accent);
      border-radius: 50%;
      box-shadow: 0 0 6px var(--accent);
    }

    .form-row {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 0.9rem;
    }

    .form-group {
      display: flex;
      flex-direction: column;
      gap: 0.4rem;
      margin-bottom: 0.9rem;
    }

    .form-group label {
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.7rem;
      color: var(--text-dim);
      letter-spacing: 0.04em;
      text-transform: uppercase;
    }

    .form-group input,
    .form-group select,
    .form-group textarea {
      width: 100%;
      padding: 0.75rem 0.9rem;
      background: var(--bg-2);
      border: 1px solid var(--line);
      border-radius: 8px;
      font-family: inherit;
      font-size: 0.9rem;
      color: var(--text);
      transition: border-color 0.2s, background 0.2s, box-shadow 0.2s;
      outline: none;
    }

    .form-group input::placeholder,
    .form-group textarea::placeholder { color: var(--muted); }

    .form-group input:focus,
    .form-group select:focus,
    .form-group textarea:focus {
      border-color: var(--accent);
      background: var(--surface-2);
      box-shadow: 0 0 0 3px var(--accent-dim);
    }

    .form-group textarea { resize: vertical; min-height: 110px; }

    .btn-submit {
      width: 100%;
      background: var(--accent);
      color: var(--bg);
      border: none;
      padding: 0.9rem;
      border-radius: var(--radius);
      font-family: inherit;
      font-size: 0.95rem;
      font-weight: 600;
      cursor: pointer;
      transition: transform 0.2s, box-shadow 0.2s;
      margin-top: 0.5rem;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 0.6rem;
      box-shadow: 0 0 0 1px var(--accent), 0 8px 24px rgba(124, 255, 158, 0.2);
    }

    .btn-submit:hover { transform: translateY(-1px); box-shadow: 0 0 0 1px var(--accent), 0 12px 32px rgba(124, 255, 158, 0.3); }

    /* FOOTER */
    footer {
      background: var(--bg);
      border-top: 1px solid var(--line);
      padding: 2.5rem 0;
    }

    .footer-inner {
      display: flex;
      align-items: center;
      justify-content: space-between;
      flex-wrap: wrap;
      gap: 1rem;
    }

    .footer-copy {
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.72rem;
      color: var(--muted);
      letter-spacing: 0.03em;
    }

    .footer-links {
      display: flex;
      gap: 1.25rem;
    }

    .footer-links a {
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.72rem;
      color: var(--text-dim);
      text-decoration: none;
      letter-spacing: 0.03em;
      transition: color 0.2s;
    }

    .footer-links a:hover { color: var(--accent); }

    /* RESPONSIVE */
    @media (max-width: 960px) {
      nav .nav-link { display: none; }
      .services-grid { grid-template-columns: 1fr; }
      .cases-grid { grid-template-columns: 1fr; }
      .usps-grid { grid-template-columns: repeat(2, 1fr); }
      .contact-wrap { grid-template-columns: 1fr; gap: 2rem; }
    }

    @media (max-width: 640px) {
      .wrap { padding: 0 1.25rem; }
      .hero { padding: 4.5rem 0 3.5rem; }
      .hero-stats { grid-template-columns: 1fr; margin-top: 3rem; }
      section.block { padding: 4.5rem 0; }
      .usps-grid { grid-template-columns: 1fr; }
      .form-row { grid-template-columns: 1fr; }
      .footer-inner { flex-direction: column; align-items: flex-start; }
      .contact-form { padding: 1.5rem; }
    }

    @media (prefers-reduced-motion: reduce) {
      *, *::before, *::after { transition: none !important; animation: none !important; }
    }
  </style>
</head>
